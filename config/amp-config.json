{
  "$schema": "https://amp-protocol.org/schemas/config.schema.json",
  "version": "1.0.0",
  
  "amp": {
    "enabled": true,
    "storage_dir": "~/.amp/agents",
    "auto_consolidate": true,
    "consolidate_interval_hours": 24,
    "sync_with_memory_bank": true,
    "memory_bank_url": "http://localhost:8100",
    
    "storage": {
      "backend": "fm",
      "enable_dry_run": true,
      "auto_commit": false,
      "fm_engine_path": "C:\\Users\\Administrator\\Desktop\\文件管理系统\\dist\\fm-cli.exe"
    },
    
    "openclaw": {
      "enabled": true,
      "gateway_url": "http://localhost:18789",
      "workspace_dir": "~/.openclaw/workspace",
      "auto_spawn_subagents": true,
      "use_skills": ["serper", "github", "weather", "coding-agent"]
    },
    
    "memory_bank": {
      "enabled": true,
      "url": "http://localhost:8100",
      "auto_sync": true,
      "min_importance": 5,
      "sync_conversations": true
    },
    
    "heartbeat": {
      "enabled": true,
      "check_interval_minutes": 30,
      "tasks": [
        {
          "name": "memory_consolidation",
          "schedule": "0 3 * * *",
          "description": "每天凌晨 3 点进行记忆巩固"
        },
        {
          "name": "sync_with_memory_bank",
          "schedule": "0 * * * *",
          "description": "每小时与 Memory Bank 同步"
        },
        {
          "name": "agent_health_check",
          "schedule": "*/30 * * * *",
          "description": "每 30 分钟检查 Agent 健康状态"
        }
      ]
    }
  },
  
  "agents": [
    {
      "name": "阿里",
      "role": "project_manager",
      "language": "zh",
      "capabilities": ["coordination", "planning", "reporting"],
      "reporting_to": "庞先生"
    },
    {
      "name": "探索者",
      "role": "researcher",
      "language": "zh",
      "capabilities": ["research", "analysis", "serper"],
      "reporting_to": "阿里"
    },
    {
      "name": "记录员",
      "role": "documenter",
      "language": "zh",
      "capabilities": ["documentation", "writing", "summarization"],
      "reporting_to": "阿里"
    },
    {
      "name": "评审员",
      "role": "quality_assurance",
      "language": "zh",
      "capabilities": ["testing", "review", "validation"],
      "reporting_to": "阿里"
    }
  ],
  
  "logging": {
    "level": "INFO",
    "file": "~/.amp/amp.log",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
  }
}
